# Copy to .env.local at the repo root. Next.js inlines NEXT_PUBLIC_* at build.
#
# RPC (optional overrides; sensible public defaults otherwise):
# NEXT_PUBLIC_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_POLYGON_RPC_URL=
# NEXT_PUBLIC_ARBITRUM_RPC_URL=
#
# ── DeFi & on-ramp protocols (this is a TEMPLATE — wire your own infra) ──
# Lending (Aave), Swap (Velora), Bridge (USDT0) need NO keys — public infra.
#
# ERC-4337 smart accounts / gasless — supply your own bundler (+ optional paymaster).
# Until set, the "Gasless" tab shows a configure notice; the integration is wired.
#   Bundler/paymaster: Pimlico, Stackup, Candide, Alchemy AA, Biconomy, …
# NEXT_PUBLIC_BUNDLER_URL=https://api.pimlico.io/v2/ethereum/rpc?apikey=YOUR_KEY
# NEXT_PUBLIC_PAYMASTER_URL=
#
# MoonPay fiat on-ramp — supply your own PUBLISHABLE key (safe for the client).
# For production, host a backend URL-signer and point NEXT_PUBLIC_MOONPAY_SIGN_URL
# at it. Defaults to MoonPay 'sandbox'.
#   Get a key: https://dashboard.moonpay.com -> Developers -> API keys
# NEXT_PUBLIC_MOONPAY_API_KEY=pk_test_YOUR_PUBLISHABLE_KEY
# NEXT_PUBLIC_MOONPAY_ENV=sandbox
# NEXT_PUBLIC_MOONPAY_SIGN_URL=https://your-backend.example.com/moonpay/sign-url
