# Shared watch-party board (optional but recommended for multi-device demos)
# Create a free Redis DB at https://upstash.com and paste REST credentials.
# Without these, rooms use in-memory storage (works for local `pnpm dev`;
# on Vercel serverless, rooms may not survive across instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional Sepolia RPC for on-chain tip verification (server-side).
# Defaults to https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_RPC_URL=
