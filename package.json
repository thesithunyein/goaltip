{
  "name": "goaltip",
  "version": "1.0.0",
  "private": true,
  "description": "GoalTip — self-custodial USDT fan tipping for football watch parties. Tether Developers Cup · WDK track.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:packages": "pnpm -F @wdk-starter/wdk-web-core build && pnpm -F @wdk-starter/wdk-ui build",
    "dev": "pnpm build:packages && pnpm -F @wdk-starter/web dev",
    "build": "pnpm build:packages && pnpm -F @wdk-starter/web build",
    "start": "pnpm -F @wdk-starter/web start",
    "typecheck": "pnpm -r --filter=\"./packages/**\" --filter=\"./apps/**\" typecheck",
    "test": "pnpm -r --filter=\"./packages/**\" --filter=\"./apps/**\" test",
    "lint": "pnpm -F @wdk-starter/web lint",
    "coach": "node coach/server.mjs",
    "pears": "node pears/server.mjs",
    "demo": "node scripts/dev-demo.mjs",
    "coach:warmup": "node scripts/coach-warmup.mjs",
    "embed:tippool": "node scripts/embed-tip-pool.mjs"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.16.0",
      "launch-editor": ">=5.4.9",
      "postcss": ">=8.5.10",
      "ws": ">=8.21.0",
      "rollup": ">=4.62.2",
      "vite": ">=6.4.3 <7",
      "vitest": "^3.2.6",
      "@vitest/runner": "^3.2.6",
      "@vitest/snapshot": "^3.2.6",
      "@vitest/spy": "^3.2.6",
      "@vitest/utils": "^3.2.6",
      "@vitest/expect": "^3.2.6",
      "@vitest/mocker": "^3.2.6",
      "@vitest/pretty-format": "^3.2.6"
    },
    "packageExtensions": {
      "@tetherto/wdk-wallet-btc": {
        "dependencies": {
          "@noble/hashes": "^1.8.0"
        }
      }
    }
  }
}
